---
import "~/styles/global.css";
import Analytics from "@vercel/analytics/astro";
import { invitation } from "~/config/invitation";
import { type Lang, pick } from "~/i18n";

interface Props {
  lang: Lang;
  title?: string;
  description?: string;
}
const { lang, title, description } = Astro.props;
const docTitle =
  title ?? `Kirab Budaya & Ruwat Bumi 2026 — ${invitation.organization.name} ${invitation.organization.location}`;
const docDesc = description ?? pick(invitation.opening, lang).slice(0, 160);

const site = Astro.site?.toString().replace(/\/$/, "") ?? "";
const path = Astro.url.pathname;
const canonical = site + path;
const altId = site + (path.startsWith("/en") ? path.replace(/^\/en\/?/, "/") : path);
const altEn = site + (path.startsWith("/en") ? path : `/en${path === "/" ? "/" : path}`);
const ogImage = site + "/og-image.jpg";

const ldEvent = {
  "@context": "https://schema.org",
  "@type": "Event",
  name: docTitle,
  description: docDesc,
  startDate: "2026-09-24T08:00:00+07:00",
  endDate: "2026-09-27T22:00:00+07:00",
  eventStatus: "https://schema.org/EventScheduled",
  eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
  location: {
    "@type": "Place",
    name: `${invitation.organization.name} ${invitation.organization.location}`,
    address: invitation.venue.address,
  },
  image: [ogImage],
  organizer: {
    "@type": "Organization",
    name: invitation.organization.foundation,
  },
};
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <meta name="theme-color" content="#4a0808" />
    <meta name="color-scheme" content="light" />
    <meta name="format-detection" content="telephone=no" />
    <title>{docTitle}</title>
    <meta name="description" content={docDesc} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="id" href={altId} />
    <link rel="alternate" hreflang="en" href={altEn} />
    <link rel="alternate" hreflang="x-default" href={altId} />

    <meta property="og:site_name" content={`${invitation.organization.name} ${invitation.organization.location}`} />
    <meta property="og:title" content={docTitle} />
    <meta property="og:description" content={docDesc} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={lang === "id" ? "id_ID" : "en_US"} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content="Tjie Thien Ta Sen Bio Tangerang" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={docTitle} />
    <meta name="twitter:description" content={docDesc} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="robots" content="index,follow,max-image-preview:large" />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- Preload hero & cover backgrounds for faster LCP -->
    <link rel="preload" as="image" href="/gallery/gate.webp" type="image/webp" fetchpriority="high" />
    <link rel="preload" as="image" href="/gallery/altar-2.webp" type="image/webp" />

    <!-- Fonts: Cormorant Garamond + Cinzel + Noto Serif SC (text= subset, only chars used) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;0,700;1,400;1,500&family=Cinzel:wght@500;600&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@500;700&text=%E6%85%88%E5%A4%A9%E5%A4%A7%E8%81%96%E5%BB%9F%E6%81%AD%E8%AB%8B%E5%85%89%E8%87%A8%E5%80%92%E6%95%B8%E8%A8%88%E6%99%82%E5%B7%A1%E9%81%8A%E5%85%B8%E5%84%80%E7%A8%8B%E8%A1%A8%E5%85%AB%E6%9C%88%E5%9B%9B%E4%BA%94%E5%85%AD%E4%B8%83%E5%8D%81%E5%BD%A1%E7%82%9D%E5%9D%9F%E5%A8%9C%E5%85%87%E6%80%85%E7%A6%8F%E6%82%B2%E5%96%9C%E6%8D%A8%E5%81%A5%E5%BA%B7%E5%B9%B3%E5%AE%89%E5%90%89%E7%A5%A5%E7%B9%81%E6%A6%AE%E5%88%86%E4%BA%AB%E9%82%80%E8%AB%8B&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify(ldEvent)} />
  </head>
  <body>
    <slot />
    <Analytics />
  </body>
</html>
