---
import { type Lang } from "~/i18n";
interface Props { lang: Lang; }
const { lang } = Astro.props;

// Curated temple images from the design bundle.
const images = [
  { src: "/gallery/temple-front-1.jpeg", caption: { id: "Pintu utama klenteng",                en: "Main entrance" } },
  { src: "/gallery/altar.jpeg",          caption: { id: "Altar Paduka YM Kongco",              en: "Altar of the Honoured Kongco" } },
  { src: "/gallery/temple-pagoda.jpeg",  caption: { id: "Pagoda klenteng",                     en: "Pagoda" } },
  { src: "/gallery/temple-front-3.jpeg", caption: { id: "Tangga utama dengan dewa penjaga",    en: "Grand stairway with guardian deities" } },
  { src: "/gallery/gate.jpeg",           caption: { id: "Gerbang Tjie Thien Ta Sen Bio",       en: "Gate of Tjie Thien Ta Sen Bio" } },
  { src: "/gallery/altar-2.jpeg",        caption: { id: "Altar dengan ornamen tradisional",    en: "Altar with traditional ornaments" } },
  { src: "/gallery/temple-side.jpeg",    caption: { id: "Sisi samping kompleks klenteng",      en: "Side view of the complex" } },
];
---
<section class="gallery">
  <div class="eyebrow">{lang === "id" ? "Galeri" : "Gallery"}</div>
  <h2 class="section-title">{lang === "id" ? "Klenteng Tjie Thien Ta Sen Bio" : "Tjie Thien Ta Sen Bio Klenteng"}</h2>
  <div class="section-han">寺 院 影 集</div>
  <div class="divider"><span class="line"></span><span class="dot"></span><span class="line"></span></div>

  <div class="gallery-rail">
    {images.map((img) => (
      <figure>
        <img src={img.src} alt={img.caption[lang]} loading="lazy" decoding="async" />
        <figcaption>{img.caption[lang]}</figcaption>
      </figure>
    ))}
  </div>
  <div class="gallery-hint">— {lang === "id" ? "Geser untuk melihat lainnya" : "Swipe to see more"} —</div>
</section>

<style>
  .gallery {
    background: var(--paper-2);
    padding: 60px 0;
    overflow: hidden;
  }
  .gallery .eyebrow,
  .gallery .section-title,
  .gallery .section-han,
  .gallery .divider { padding-left: 30px; padding-right: 30px; }

  .gallery-rail {
    display: flex; gap: 14px;
    padding: 10px 30px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
  }
  .gallery-rail::-webkit-scrollbar { display: none; }
  .gallery-rail figure {
    flex: 0 0 78%;
    scroll-snap-align: center;
    position: relative;
    border: 1px solid var(--gold);
    background: var(--red-deep);
    overflow: hidden;
    margin: 0;
  }
  .gallery-rail figure img {
    width: 100%; height: 280px; object-fit: cover; display: block;
  }
  .gallery-rail figcaption {
    position: absolute; left: 0; right: 0; bottom: 0;
    padding: 10px 12px;
    font-family: var(--font-display);
    font-style: italic; font-size: 13px;
    color: var(--paper);
    background: linear-gradient(0deg, rgba(0, 0, 0, 0.7), transparent);
  }
  .gallery-hint {
    text-align: center; margin-top: 12px;
    font-family: var(--font-cap); font-size: 9px; letter-spacing: 0.4em;
    color: var(--red); opacity: 0.6;
    text-transform: uppercase;
  }

  @media (min-width: 720px) {
    .gallery .eyebrow,
    .gallery .section-title,
    .gallery .section-han,
    .gallery .divider { padding-left: 60px; padding-right: 60px; }
    .gallery-rail { padding: 10px 60px; }
    .gallery-rail figure { flex: 0 0 60%; }
    .gallery-rail figure img { height: 360px; }
  }
  @media (min-width: 1080px) {
    .gallery-rail {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 18px;
      overflow: visible;
      padding: 10px 60px;
      scroll-snap-type: none;
    }
    .gallery-rail figure { flex: none; scroll-snap-align: none; }
    .gallery-rail figure img { height: 280px; }
    .gallery-hint { display: none; }
  }
</style>
