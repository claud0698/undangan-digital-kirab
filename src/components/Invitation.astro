---
import Base from "~/layouts/Base.astro";
import LangToggle from "./LangToggle.astro";
import CoverGate from "./CoverGate.astro";
import Hero from "./Hero.astro";
import Countdown from "./Countdown.astro";
import About from "./About.astro";
import Schedule from "./Schedule.astro";
import Sponsors from "./Sponsors.astro";
import Footer from "./Footer.astro";
import Audio from "./Audio.astro";
import { type Lang } from "~/i18n";

interface Props { lang: Lang; }
const { lang } = Astro.props;
---
<Base lang={lang}>
  {/* Language toggle hidden for now — site stays in ID. Re-enable to restore EN switch. */}
  {/* <LangToggle lang={lang} /> */}
  <div class="shell">
    <CoverGate lang={lang} />
    <Hero lang={lang} />
    <Countdown lang={lang} />
    <About lang={lang} />
    <Schedule lang={lang} />
    <Sponsors lang={lang} />
    <Footer lang={lang} />
  </div>
  <Audio lang={lang} />
</Base>
