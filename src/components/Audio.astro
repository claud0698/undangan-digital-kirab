---
import { type Lang } from "~/i18n";
interface Props { lang: Lang; src?: string; }
const { lang, src = "/audio/song" } = Astro.props;
const label = lang === "id" ? "Putar / hentikan musik" : "Play / pause music";
---
<audio id="bgm" loop preload="auto" playsinline>
  <source src={`${src}.mp3`} type="audio/mpeg" />
  <source src={`${src}.ogg`} type="audio/ogg" />
</audio>

<button id="bgmToggle" class="bgm-toggle" type="button" aria-label={label} aria-pressed="false" hidden>
  <span class="bgm-eq" aria-hidden="true"><i></i><i></i><i></i><i></i></span>
  <svg class="bgm-note" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
    <path d="M9 18V6l10-2v12" />
    <circle cx="6" cy="18" r="3" />
    <circle cx="16" cy="16" r="3" />
  </svg>
</button>

<style>
  .bgm-toggle {
    position: fixed;
    right: 18px; bottom: 18px;
    z-index: 210; /* above the intro overlay (200) so it shows on the cover too */
    width: 52px; height: 52px;
    display: grid; place-items: center;
    border-radius: 50%;
    background: var(--red-deep);
    color: var(--gold-pale);
    border: 1px solid var(--gold);
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.35), inset 0 0 0 3px rgba(184, 133, 54, 0.35);
    cursor: pointer;
    opacity: 0.8;
    transition: transform 0.2s ease, box-shadow 0.2s ease, opacity 0.2s ease;
  }
  .bgm-toggle:hover { transform: translateY(-2px); opacity: 1; }
  .bgm-toggle:focus-visible { outline: 2px solid var(--gold-bright); outline-offset: 3px; }

  /* paused: music note, gently bobbing so the logo always feels alive */
  /* both icons stack in the same cell and cross-fade for a smooth swap */
  .bgm-note, .bgm-eq { grid-area: 1 / 1; transition: opacity 0.4s ease; }

  .bgm-note {
    width: 22px; height: 22px; color: var(--gold-bright);
    opacity: 1;
    animation: bgm-bob 4.8s ease-in-out infinite;
  }
  @keyframes bgm-bob {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50%      { transform: translateY(-2px) rotate(-4deg); }
  }

  /* playing: animated equalizer bars */
  .bgm-eq { display: flex; align-items: flex-end; gap: 3px; height: 18px; opacity: 0; }
  .bgm-eq i {
    width: 3px; height: 100%;
    background: var(--gold-bright);
    transform-origin: bottom;
    animation: bgm-bounce 1.8s ease-in-out infinite;
  }
  .bgm-eq i:nth-child(2) { animation-delay: 0.3s; }
  .bgm-eq i:nth-child(3) { animation-delay: 0.6s; }
  .bgm-eq i:nth-child(4) { animation-delay: 0.9s; }

  .bgm-toggle.playing .bgm-note { opacity: 0; }
  .bgm-toggle.playing .bgm-eq { opacity: 1; }

  @keyframes bgm-bounce {
    0%, 100% { transform: scaleY(0.35); }
    50%      { transform: scaleY(1); }
  }
  @media (prefers-reduced-motion: reduce) {
    .bgm-eq i, .bgm-note { animation: none; }
    .bgm-eq i { transform: scaleY(0.7); }
    .bgm-toggle { transition: none; }
  }
  @media (min-width: 720px) {
    .bgm-toggle { right: 26px; bottom: 26px; width: 56px; height: 56px; }
  }
</style>

<script>
  const audio = document.getElementById("bgm") as HTMLAudioElement | null;
  const btn = document.getElementById("bgmToggle") as HTMLButtonElement | null;
  if (audio && btn) {
    const STORE_KEY = "bgm-muted";
    const DELAY_MS = 2000; // gentle wait before the first note, so it isn't jarring
    const FADE_MS = 1200;  // ease the volume in
    let ready = false;
    let startTimer = 0;
    let fadeTimer = 0;

    const setUI = (playing: boolean) => {
      btn.classList.toggle("playing", playing);
      btn.setAttribute("aria-pressed", String(playing));
    };
    const muted = () => localStorage.getItem(STORE_KEY) === "1";

    const fadeIn = () => {
      clearInterval(fadeTimer);
      audio.volume = 0;
      const step = 60;
      let t = 0;
      fadeTimer = window.setInterval(() => {
        t += step;
        audio.volume = Math.min(1, t / FADE_MS);
        if (t >= FADE_MS) clearInterval(fadeTimer);
      }, step);
    };

    // Immediate play (used by the manual toggle). fade/fromStart optional.
    const play = async (fromStart = false, fade = false) => {
      clearTimeout(startTimer);
      if (fromStart) audio.currentTime = 0;
      try {
        if (fade) audio.volume = 0;
        await audio.play();
        setUI(true);
        localStorage.removeItem(STORE_KEY);
        if (fade) fadeIn();
      } catch {
        setUI(false);
      }
    };

    // Delayed, faded start from the beginning — used for the auto/first-gesture
    // entrance so the music eases in instead of hitting the visitor at once.
    const playSoon = () => {
      if (muted() || !audio.paused) return;
      clearTimeout(startTimer);
      startTimer = window.setTimeout(() => play(true, true), DELAY_MS);
    };

    const pause = () => {
      clearTimeout(startTimer);
      clearInterval(fadeTimer);
      audio.pause();
      setUI(false);
      localStorage.setItem(STORE_KEY, "1");
    };

    // Start on the FIRST interaction anywhere — tap, scroll, key — so the song
    // eases in while the visitor is still on the cover screen, before they even
    // press "Buka Undangan".
    const firstGesture = () => { playSoon(); remove(); };
    const evs = ["pointerdown", "touchstart", "keydown", "scroll"] as const;
    const remove = () => evs.forEach((e) => window.removeEventListener(e, firstGesture));
    evs.forEach((e) => window.addEventListener(e, firstGesture, { passive: true }));

    // Reveal the control once a real audio file has loaded; try to autostart.
    audio.addEventListener("loadeddata", () => {
      ready = true;
      btn.hidden = false;
      playSoon();
    });
    // No file / failed source: keep everything hidden, log once.
    audio.addEventListener("error", () => {
      btn.hidden = true;
      remove();
      console.warn("[bgm] no playable audio at /audio/song.mp3 — drop a file in public/audio/ to enable music.");
    });

    // Opening the invitation also guarantees the (delayed, faded) start.
    document.getElementById("openBtn")?.addEventListener("click", () => {
      if (ready) playSoon();
    });

    // Manual toggle = instant response (resume where it left off, no delay).
    btn.addEventListener("click", () => {
      if (audio.paused) play(false, false);
      else pause();
    });

    // Pause in background, resume when the tab is focused again.
    let resumeOnReturn = false;
    document.addEventListener("visibilitychange", () => {
      if (document.hidden) {
        resumeOnReturn = !audio.paused;
        if (resumeOnReturn) audio.pause();
      } else if (resumeOnReturn && !muted()) {
        audio.play().catch(() => {});
      }
    });
  }
</script>
