---
// Decorative SVGs used across the page.
// All placed and sized via the .corner / .topo classes in global.css.
interface Props {
  variant: "cloud-corner" | "topo-lines" | "anniversary-badge" | "monkey-king";
  class?: string;
  invert?: boolean;
}
const { variant, class: className = "", invert = false } = Astro.props;
const fill = invert ? "var(--paper-soft)" : "var(--crimson)";
const trim = invert ? "var(--gold-bright)" : "var(--gold)";
---

{variant === "cloud-corner" && (
  <svg viewBox="0 0 220 220" class={className} aria-hidden="true">
    {/* Stylised filled cloud (yún wén) — three lobes with gold trim */}
    <g fill={fill} stroke={trim} stroke-width="2.4" stroke-linejoin="round">
      <path d="M0 220 V150 Q10 130 30 130 Q40 100 70 105 Q80 80 110 90 Q130 70 155 90 Q180 80 195 110 Q220 110 220 140 V220 Z"/>
      <path d="M30 220 V180 Q45 175 55 185 Q65 170 85 175 Q100 160 120 175 Q140 165 155 185 Q170 175 185 195 V220 Z" fill={trim} opacity="0.55" stroke="none"/>
    </g>
    <g fill="none" stroke={trim} stroke-width="1.6" stroke-linecap="round">
      {/* Inner curl spirals */}
      <path d="M55 175 q-6 -10 4 -16 q10 -4 12 6 q1 8 -8 8" />
      <path d="M115 165 q-7 -12 5 -18 q12 -4 14 7 q1 9 -10 9" />
      <path d="M170 180 q-6 -10 4 -16 q10 -4 12 6 q1 8 -8 8" />
    </g>
  </svg>
)}

{variant === "topo-lines" && (
  <svg viewBox="0 0 320 200" class={className} aria-hidden="true">
    <g fill="none" stroke="var(--crimson)" stroke-width="1.4" stroke-linecap="round" opacity="0.55">
      <path d="M320 10 q-40 8 -70 0 t-60 8 t-70 -6 t-80 14 t-40 -4" stroke-dasharray="2 4"/>
      <path d="M320 30 q-30 14 -70 6 t-60 12 t-70 -2 t-80 18" stroke-dasharray="2 4"/>
      <path d="M320 60 q-50 4 -80 -8 t-70 14 t-90 -10 t-80 22"/>
      <path d="M320 90 q-40 18 -90 -2 t-80 18 t-100 -8"/>
      <path d="M320 120 q-60 -4 -90 12 t-100 -10 t-130 24" stroke-dasharray="3 6"/>
      <path d="M320 150 q-40 12 -100 -6 t-100 22 t-120 -10"/>
      <path d="M320 180 q-50 -4 -100 14 t-120 -8 t-100 24" stroke-dasharray="2 5"/>
    </g>
  </svg>
)}

{variant === "anniversary-badge" && (
  <svg viewBox="0 0 160 160" class={className} aria-hidden="true">
    <defs>
      <linearGradient id="agold" x1="0" x2="0" y1="0" y2="1">
        <stop offset="0" stop-color="#F2D27A"/>
        <stop offset="1" stop-color="#A8761B"/>
      </linearGradient>
    </defs>
    {/* stars */}
    <g fill="var(--crimson)">
      <path d="M40 18 l3 8 l8 1 l-6 6 l2 8 l-7 -4 l-7 4 l2 -8 l-6 -6 l8 -1 z"/>
      <path d="M80 8 l3 8 l8 1 l-6 6 l2 8 l-7 -4 l-7 4 l2 -8 l-6 -6 l8 -1 z"/>
      <path d="M120 18 l3 8 l8 1 l-6 6 l2 8 l-7 -4 l-7 4 l2 -8 l-6 -6 l8 -1 z"/>
    </g>
    {/* "43" disc */}
    <circle cx="80" cy="86" r="50" fill="url(#agold)" stroke="var(--crimson-deep)" stroke-width="3"/>
    <circle cx="80" cy="86" r="44" fill="none" stroke="var(--paper-soft)" stroke-width="1.5" stroke-dasharray="2 4"/>
    <text x="80" y="98" text-anchor="middle"
          font-family="Antonio, Bebas Neue, sans-serif" font-weight="700"
          font-size="46" fill="var(--crimson-deep)">43</text>
    {/* ribbon */}
    <g>
      <path d="M28 122 L132 122 L122 152 L80 142 L38 152 Z" fill="var(--crimson)" stroke="var(--crimson-deep)" stroke-width="2"/>
      <text x="80" y="142" text-anchor="middle"
            font-family="Antonio, Bebas Neue, sans-serif" font-weight="700"
            font-size="13" letter-spacing="2.5" fill="var(--paper-soft)">ANNIVERSARY</text>
    </g>
  </svg>
)}

{variant === "monkey-king" && (
  <svg viewBox="0 0 200 260" class={className} aria-hidden="true">
    {/* Sun Wukong silhouette — stylised, reads as Monkey King with staff */}
    <g fill="var(--crimson-deep)" stroke="var(--gold)" stroke-width="1.6" stroke-linejoin="round">
      {/* staff */}
      <line x1="170" y1="6" x2="40" y2="252" stroke="var(--gold)" stroke-width="3"/>
      <circle cx="170" cy="6" r="4" fill="var(--gold)"/>
      <circle cx="40" cy="252" r="4" fill="var(--gold)"/>
      {/* head + crown headband */}
      <path d="M88 50 q-22 -4 -22 24 q0 30 30 32 q30 -2 30 -32 q0 -28 -22 -24 q-3 -8 -8 -10 q-5 2 -8 10 z"/>
      <path d="M70 60 q30 -10 60 0 l-4 8 q-26 -8 -52 0 z" fill="var(--gold)"/>
      {/* eyes */}
      <circle cx="85" cy="80" r="2.5" fill="var(--gold-bright)"/>
      <circle cx="111" cy="80" r="2.5" fill="var(--gold-bright)"/>
      {/* armor body */}
      <path d="M70 110 q-12 8 -16 30 q-2 30 8 60 q-6 18 0 38 q14 12 36 14 q22 -2 36 -14 q6 -20 0 -38 q10 -30 8 -60 q-4 -22 -16 -30 q-12 8 -28 8 q-16 0 -28 -8 z"/>
      {/* belt */}
      <rect x="68" y="170" width="64" height="10" fill="var(--gold)"/>
      {/* shoulder pads */}
      <path d="M62 116 q-10 6 -10 22 q12 -6 16 -16 z" fill="var(--gold)"/>
      <path d="M138 116 q10 6 10 22 q-12 -6 -16 -16 z" fill="var(--gold)"/>
    </g>
  </svg>
)}
