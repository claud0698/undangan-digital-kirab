---
import { invitation } from "~/config/invitation";
import { type Lang } from "~/i18n";
interface Props { lang: Lang; }
const { lang } = Astro.props;
const shareText = encodeURIComponent(
  `${lang === "id"
    ? "Mari hadiri Kirab Budaya & Ruwat Bumi 2026 — Sejit YMS Tjie Thien Ta Sen & HUT Tjie Thien Ta Sen Bio Ke-43, 24–27 September 2026. Selengkapnya: "
    : "Join Kirab Budaya & Ruwat Bumi 2026 — Tjie Thien Ta Sen Bio's 43rd Anniversary, 24–27 September 2026. More: "}`
);
---

<!-- SHARE -->
<section class="share-section">
  <div class="eyebrow">{lang === "id" ? "Bagikan" : "Share"}</div>
  <h2 class="section-title">{lang === "id" ? "Sebarkan Undangan" : "Spread the Invitation"}</h2>
  <div class="section-han">分 享 邀 請</div>
  <div class="section-han-roman">{lang === "id" ? "Bagikan Kepada Sahabat" : "Share with Friends"}</div>
  <div class="divider"><span class="line"></span><span class="dot"></span><span class="line"></span></div>

  <p style="font-family:'Cormorant Garamond',serif;font-style:italic;font-size:15px;color:var(--ink);opacity:.8;line-height:1.6;max-width:340px;margin:0 auto">
    {lang === "id"
      ? "Mohon bantuan menyampaikan informasi ini kepada umat dan simpatisan lainnya."
      : "Kindly help relay this invitation to fellow devotees and friends."}
  </p>

  <div class="share-row">
    <a class="share-btn" id="shareWA" target="_blank" rel="noopener">
      <svg viewBox="0 0 24 24"><path d="M17.5 14.4c-.3-.1-1.7-.8-1.9-.9-.3-.1-.4-.1-.6.1s-.7.9-.9 1c-.2.2-.3.2-.6.1-1-.5-1.7-.9-2.4-2-.2-.3.2-.3.5-1 .1-.1 0-.3 0-.4 0-.1-.6-1.4-.8-2-.2-.5-.4-.4-.6-.4h-.5c-.2 0-.4.1-.6.3-.2.2-.8.8-.8 2 0 1.1.8 2.2 1 2.4.1.1 1.7 2.7 4.2 3.7 2 .8 2.4.7 2.8.7.4 0 1.4-.6 1.6-1.1.2-.5.2-1 .1-1.1 0-.1-.2-.2-.5-.4M12 2C6.5 2 2 6.5 2 12c0 1.8.5 3.5 1.3 5L2 22l5.2-1.3c1.4.8 3.1 1.2 4.8 1.2 5.5 0 10-4.5 10-10S17.5 2 12 2"/></svg>
      WhatsApp
    </a>
    <button class="share-btn" id="shareCopy">
      <svg viewBox="0 0 24 24"><path d="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1m3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2m0 16H8V7h11v14z"/></svg>
      <span id="copyLabel">{lang === "id" ? "Salin Link" : "Copy Link"}</span>
    </button>
  </div>
</section>

<!-- CLOSING -->
<section class="closing-section">
  <div class="seal">福</div>
  <div class="han">慈 悲 喜 捨</div>
  <div class="han-roman">{lang === "id"
    ? "Cinta Kasih, Welas Asih, Suka Cita, Pelepasan"
    : "Loving-kindness, Compassion, Joy, Equanimity"}</div>
  <h3>
    Sukhi Hontu · Amithofo<br />
    {lang === "id" ? "Salam Kebajikan" : "Blessings of Virtue"}
  </h3>
  <p>
    {lang === "id"
      ? "Semoga kesehatan, keselamatan, perlindungan, dan kemakmuran senantiasa menyertai seluruh umat dan simpatisan."
      : "May health, safety, protection, and prosperity always accompany all devotees and friends."}
  </p>

  <div class="blessings">
    <div class="bless"><span class="bless-han">健 康</span><span class="bless-id">{lang === "id" ? "Kesehatan" : "Health"}</span></div>
    <div class="bless"><span class="bless-han">平 安</span><span class="bless-id">{lang === "id" ? "Keselamatan" : "Safety"}</span></div>
    <div class="bless"><span class="bless-han">吉 祥</span><span class="bless-id">{lang === "id" ? "Keberuntungan" : "Fortune"}</span></div>
    <div class="bless"><span class="bless-han">繁 榮</span><span class="bless-id">{lang === "id" ? "Kemakmuran" : "Prosperity"}</span></div>
  </div>

  <div class="signoff">— {invitation.organization.foundation} —</div>
  <div style="font-family:'Cormorant Garamond',serif;font-style:italic;font-size:13px;color:var(--gold-pale);opacity:.7;margin-top:12px">
    {invitation.organization.name} · {invitation.organization.location} · Imlek 2577
  </div>
</section>

<script is:inline define:vars={{ shareText, copiedLabel: lang === "id" ? "Tersalin ✓" : "Copied ✓", copyDefault: lang === "id" ? "Salin Link" : "Copy Link" }}>
  const shareWA = document.getElementById("shareWA");
  const shareCopy = document.getElementById("shareCopy");
  const copyLabel = document.getElementById("copyLabel");
  function getShareUrl() { return window.location.href.split("#")[0]; }
  if (shareWA) shareWA.href = "https://wa.me/?text=" + shareText + encodeURIComponent(getShareUrl());
  shareCopy?.addEventListener("click", async () => {
    try {
      await navigator.clipboard.writeText(getShareUrl());
      if (copyLabel) {
        copyLabel.textContent = copiedLabel;
        setTimeout(() => (copyLabel.textContent = copyDefault), 1800);
      }
    } catch {}
  });
</script>
