---
import { invitation } from "~/config/invitation";
import { type Lang } from "~/i18n";
interface Props { lang: Lang; }
const { lang } = Astro.props;

const cornerSvg = `<svg viewBox="0 0 90 90"><g fill="none" stroke="#d8a847" stroke-width="1"><path d="M 5 5 L 40 5 M 5 5 L 5 40 M 5 12 L 28 12 L 28 5 M 12 5 L 12 28 L 5 28 M 14 14 L 22 14 L 22 22 L 14 22 Z"/></g></svg>`;
const overlayCornerSvg = `<svg viewBox="0 0 60 60"><path d="M 1 1 L 25 1 M 1 1 L 1 25 M 1 8 L 18 8 L 18 1 M 8 1 L 8 18 L 1 18"/></svg>`;
const lanternSvg = `<svg viewBox="0 0 60 100" xmlns="http://www.w3.org/2000/svg"><line x1="30" y1="0" x2="30" y2="14" stroke="rgba(255,220,160,.5)" stroke-width=".8"/><rect x="22" y="13" width="16" height="5" fill="url(#lanternCap)" rx="1"/><ellipse cx="30" cy="42" rx="26" ry="24" fill="url(#lanternBody)"/><path d="M 6 38 Q 30 44 54 38" stroke="rgba(0,0,0,.25)" stroke-width=".6" fill="none"/><path d="M 5 46 Q 30 52 55 46" stroke="rgba(0,0,0,.25)" stroke-width=".6" fill="none"/><rect x="22" y="65" width="16" height="5" fill="url(#lanternCap)" rx="1"/><line x1="30" y1="70" x2="30" y2="78" stroke="#b48536" stroke-width="1.2"/><line x1="26" y1="78" x2="26" y2="96" stroke="#e8b455" stroke-width=".8"/><line x1="30" y1="78" x2="30" y2="98" stroke="#e8b455" stroke-width=".8"/><line x1="34" y1="78" x2="34" y2="96" stroke="#e8b455" stroke-width=".8"/><circle cx="30" cy="42" r="2" fill="#fff3a0" opacity=".7"/></svg>`;
---

<!-- shared lantern gradients (defined once, reused via <use>) -->
<svg width="0" height="0" style="position:absolute" aria-hidden="true">
  <defs>
    <radialGradient id="lanternBody" cx="35%" cy="40%" r="65%">
      <stop offset="0%" stop-color="#ff8a4a"/>
      <stop offset="35%" stop-color="#e02828"/>
      <stop offset="75%" stop-color="#9a1212"/>
      <stop offset="100%" stop-color="#5a0606"/>
    </radialGradient>
    <linearGradient id="lanternCap" x1="0" x2="0" y1="0" y2="1">
      <stop offset="0%" stop-color="#f3d068"/>
      <stop offset="50%" stop-color="#b48536"/>
      <stop offset="100%" stop-color="#7a5418"/>
    </linearGradient>
  </defs>
</svg>

<!-- INTRO OVERLAY -->
<div class="intro-overlay" id="introOverlay">
  <div class="corner c-tl" set:html={overlayCornerSvg} />
  <div class="corner c-tr" set:html={overlayCornerSvg} />
  <div class="corner c-bl" set:html={overlayCornerSvg} />
  <div class="corner c-br" set:html={overlayCornerSvg} />

  <div class="han">齊天大聖</div>
  <div class="han-roman">Tjie Thien Ta Sen</div>
  <div class="label">
    {lang === "id" ? "Kirab Budaya · Imlek 2577" : "Cultural Procession · Lunar 2577"}
  </div>
  <h1>
    {lang === "id"
      ? <>Kirab Budaya & Ruwat Bumi 2026<br />Tjie Thien Ta Sen Bio Tangerang</>
      : <>Cultural Procession & Earth Blessing 2026<br />Tjie Thien Ta Sen Bio Tangerang</>}
  </h1>
  <div class="sub">{invitation.dateRange[lang]}</div>
  <div class="to">{lang === "id" ? "Kepada Yang Terhormat" : "To Our Honoured Guests"}</div>
  <div class="guest" id="guestName">{lang === "id" ? "Bapak / Ibu Umat" : "Dear Devotees & Friends"}</div>
  <button class="open-btn" id="openBtn">{lang === "id" ? "Buka Undangan" : "Open Invitation"}</button>
</div>

<!-- COVER -->
<div class="cover">
  <div class="cover-bg"></div>

  <div class="lanterns" aria-hidden="true">
    <div class="lantern"><div class="lantern-glow"></div><Fragment set:html={lanternSvg} /></div>
    <div class="lantern"><div class="lantern-glow"></div><Fragment set:html={lanternSvg} /></div>
    <div class="lantern"><div class="lantern-glow"></div><Fragment set:html={lanternSvg} /></div>
    <div class="lantern"><div class="lantern-glow"></div><Fragment set:html={lanternSvg} /></div>
    <div class="lantern"><div class="lantern-glow"></div><Fragment set:html={lanternSvg} /></div>
  </div>

  <div class="corner c-tl" set:html={cornerSvg} />
  <div class="corner c-tr" set:html={cornerSvg} />
  <div class="corner c-bl" set:html={cornerSvg} />
  <div class="corner c-br" set:html={cornerSvg} />

  <div class="cover-content">
    <div class="anniv">— {lang === "id" ? "Memperingati HUT ke-43 Tahun" : "Celebrating the 43rd Anniversary"} —</div>
    <h1>{invitation.organization.name} · {invitation.organization.location}</h1>

    <div class="seal">齊</div>

    <h2>{lang === "id" ? "Kirab Budaya & Ruwat Bumi 2026" : "Cultural Procession & Earth Blessing 2026"}</h2>
    <h3>
      {lang === "id"
        ? <>Sejit YMS<br />Tjie Thien Ta Sen</>
        : <>Birthday of YMS<br />Tjie Thien Ta Sen</>}
    </h3>
    <div class="subname">— {lang === "id" ? "Semarak Harmoni Budaya & Tradisi" : "A Celebration of Cultural Harmony"} —</div>

    <div class="meta">PWE GWEE 13 — 17 · IMLEK 2577</div>
    <div class="dates">
      23 <span style="color:#b48536">·</span> 24 <span style="color:#b48536">·</span> 25 <span style="color:#b48536">·</span> 26 <span style="color:#b48536">·</span> 27
    </div>
    <div class="lunar" style="margin-top:6px;font-family:'Cinzel',serif;letter-spacing:.4em;font-size:14px;color:#e9cf86">SEPTEMBER 2026</div>

    <div class="scroll-cue">↓ &nbsp;&nbsp; SCROLL &nbsp;&nbsp; ↓</div>
  </div>
</div>

<script>
  const urlParams = new URLSearchParams(window.location.search);
  const guest = urlParams.get("to") || urlParams.get("nama");
  if (guest) {
    const el = document.getElementById("guestName");
    if (el) el.textContent = decodeURIComponent(guest);
  }

  const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;

  // Gentle auto-scroll: drifts the page down slowly, pauses the moment the
  // visitor scrolls themselves, and resumes after 5s of no interaction.
  const RESUME_MS = 5000;  // delay before (re)starting the drift
  // Drift speed in px/second. Override via PUBLIC_SCROLL_SPEED env var (.env).
  const SPEED = Number(import.meta.env.PUBLIC_SCROLL_SPEED) || 40;
  let rafId = 0, idleTimer = 0, active = false, pos = 0, lastT = 0;
  const maxScroll = () => document.documentElement.scrollHeight - window.innerHeight;

  const stopAuto = () => { active = false; cancelAnimationFrame(rafId); };
  const startAuto = () => {
    if (active || reduce || window.scrollY >= maxScroll() - 1) return;
    active = true;
    pos = window.scrollY;
    lastT = 0;
    const step = (t: number) => {
      if (!active) return;
      const dt = lastT ? (t - lastT) / 1000 : 0;
      lastT = t;
      pos = Math.min(maxScroll(), pos + SPEED * dt);
      window.scrollTo(0, pos);
      if (pos >= maxScroll()) { active = false; return; }
      rafId = requestAnimationFrame(step);
    };
    rafId = requestAnimationFrame(step);
  };
  const scheduleResume = () => { clearTimeout(idleTimer); idleTimer = window.setTimeout(startAuto, RESUME_MS); };

  // A real scroll gesture (wheel / touch drag / nav keys) pauses the drift,
  // then it resumes 5s later. Taps and our own scrollTo don't count.
  const onUserScroll = () => { stopAuto(); scheduleResume(); };
  ["wheel", "touchmove", "keydown"].forEach((e) => window.addEventListener(e, onUserScroll, { passive: true }));

  const overlay = document.getElementById("introOverlay") as HTMLElement | null;
  const openBtn = document.getElementById("openBtn");
  document.body.style.overflow = "hidden";
  openBtn?.addEventListener("click", () => {
    overlay?.classList.add("hidden");
    document.body.style.overflow = "";
    setTimeout(() => overlay?.remove(), 900);
    // Begin the gentle drift a few seconds after the cover is revealed.
    scheduleResume();
  });

  // Fun: tap or tap-and-hold-drag a lantern. Motion is a damped-spring pendulum
  // (damped harmonic oscillator, like Apple CASpringAnimation / wobble /
  // react-spring): angle eases toward a target with momentum and natural decay.
  if (!reduce) {
    const STIFFNESS = 150; // restoring force toward rest
    const DAMPING = 9;     // friction (lower = more sway before settling)
    const MAX_DEG = 26;    // clamp how far a drag can pull it

    document.querySelectorAll<HTMLElement>(".lantern").forEach((l) => {
      let angle = 0, vel = 0, target = 0, raf = 0, last = 0;
      let grabbing = false, startX = 0, startAngle = 0, moved = 0;

      const frame = (now: number) => {
        let dt = (now - last) / 1000;
        last = now;
        if (dt > 0.04) dt = 0.04; // clamp after tab-switch / jank
        // semi-implicit Euler integration of a damped spring
        const accel = -STIFFNESS * (angle - target) - DAMPING * vel;
        vel += accel * dt;
        angle += vel * dt;
        l.style.transform = `rotate(${angle}deg)`;
        if (!grabbing && Math.abs(angle - target) < 0.05 && Math.abs(vel) < 0.05) {
          // settled — hand control back to the idle CSS sway
          l.style.transform = "";
          l.classList.remove("springing");
          raf = 0;
          return;
        }
        raf = requestAnimationFrame(frame);
      };
      const run = () => {
        if (raf) return;
        l.classList.add("springing");
        last = performance.now();
        raf = requestAnimationFrame(frame);
      };

      l.addEventListener("pointerdown", (e) => {
        grabbing = true;
        moved = 0;
        startX = e.clientX;
        startAngle = angle;
        l.classList.add("grabbing");
        try { l.setPointerCapture(e.pointerId); } catch {}
        run();
      });
      l.addEventListener("pointermove", (e) => {
        if (!grabbing) return;
        const dx = e.clientX - startX;
        moved = Math.max(moved, Math.abs(dx));
        // pivot is top-center: +angle swings the body LEFT, so negate dx
        // to make the lantern body follow the pointer/finger.
        target = Math.max(-MAX_DEG, Math.min(MAX_DEG, startAngle - dx * 0.35));
      });
      const release = () => {
        if (!grabbing) return;
        grabbing = false;
        l.classList.remove("grabbing");
        target = 0; // swing back to rest
        if (moved < 4) vel += (Math.random() < 0.5 ? -1 : 1) * 170; // a tap: random-direction impulse
        run();
      };
      l.addEventListener("pointerup", release);
      l.addEventListener("pointercancel", release);
    });
  }

  // Subtle parallax on cover bg (scroll-triggered, passive)
  const coverBg = document.querySelector<HTMLElement>(".cover-bg");
  window.addEventListener(
    "scroll",
    () => {
      const y = window.scrollY;
      if (y < 800 && coverBg) coverBg.style.transform = `translateY(${y * 0.3}px) scale(${1 + y * 0.0003})`;
    },
    { passive: true },
  );
</script>
