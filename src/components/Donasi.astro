---
import { invitation } from "~/config/invitation";
import { type Lang, pick } from "~/i18n";
interface Props { lang: Lang; }
const { lang } = Astro.props;
---
<section class="sponsorship">
  <div class="eyebrow">{lang === "id" ? "Dukungan" : "Sponsorship"}</div>
  <h2 class="section-title">{lang === "id" ? "Penawaran Sponsorship" : "Sponsorship Tiers"}</h2>
  <div class="section-han">護 持 緣 主</div>
  <div class="divider"><span class="line"></span><span class="dot"></span><span class="line"></span></div>

  <p class="lead">
    {lang === "id"
      ? "Kami membuka beberapa paket kerja sama bagi para sponsor & donatur yang berkenan mendukung Kirab Budaya & Ruwat Bumi 2026."
      : "We offer several partnership packages for sponsors and donors who wish to support the Kirab Budaya & Ruwat Bumi 2026."}
  </p>

  <ol class="tiers">
    {invitation.sponsors.map((s) => (
      <li class="tier">
        <header>
          <span class="rank">{s.rank}</span>
          <h3>{pick(s.name, lang)}</h3>
        </header>
        <p class="contrib">{pick(s.contribution, lang)}</p>
        <ul class="perks">
          {s.perks.map((p) => <li>{pick(p, lang)}</li>)}
        </ul>
        {s.badge && <p class="badge">{pick(s.badge, lang)}</p>}
      </li>
    ))}
  </ol>

  <p class="footnote">
    <em>{pick(invitation.sponsorNote, lang)}</em>
  </p>
</section>

<style>
  .sponsorship {
    background: var(--paper-2);
    padding: 70px 30px;
  }
  .sponsorship .eyebrow { color: var(--red); }

  .lead {
    font-family: var(--font-display);
    font-style: italic;
    text-align: center;
    color: var(--ink);
    opacity: 0.85;
    max-width: 460px;
    margin: 0 auto 2rem;
    font-size: 16px;
    line-height: 1.6;
  }

  .tiers {
    list-style: none; padding: 0;
    display: flex; flex-direction: column; gap: 14px;
  }
  .tier {
    background: var(--paper);
    border: 1px solid var(--gold);
    padding: 22px;
  }
  .tier header {
    display: flex; align-items: baseline; gap: 14px;
    border-bottom: 1px dashed rgba(122, 16, 16, 0.25);
    padding-bottom: 0.85rem;
    margin-bottom: 0.85rem;
  }
  .tier .rank {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 38px;
    color: var(--gold);
    line-height: 1;
  }
  .tier h3 {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 600;
    color: var(--red-deep);
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .tier .contrib {
    font-family: var(--font-cap);
    font-size: 11px; letter-spacing: 0.25em;
    color: var(--red); text-transform: uppercase;
    margin-bottom: 0.6rem;
  }
  .tier .perks {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 0.35rem;
  }
  .tier .perks li {
    font-family: var(--font-display);
    font-size: 15px;
    color: var(--ink);
    line-height: 1.5;
    padding-left: 1rem;
    position: relative;
  }
  .tier .perks li::before {
    content: "❖";
    position: absolute;
    left: 0;
    color: var(--gold);
    opacity: 0.7;
    font-size: 11px;
    top: 0.25em;
  }
  .tier .badge {
    display: inline-block;
    margin-top: 0.85rem;
    font-family: var(--font-cap);
    font-size: 9px;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    background: var(--red-deep);
    color: var(--gold-pale);
    padding: 4px 12px;
  }

  .footnote {
    margin-top: 2rem;
    text-align: center;
    font-family: var(--font-display);
    color: var(--ink);
    opacity: 0.8;
    font-size: 14px;
    line-height: 1.6;
    max-width: 480px;
    margin-inline: auto;
  }
  .footnote em { color: var(--red); }

  @media (min-width: 720px) {
    .tier h3 { font-size: 26px; }
    .tier .rank { font-size: 48px; }
  }
  @media (min-width: 1080px) {
    .tiers {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 18px;
    }
  }
</style>
