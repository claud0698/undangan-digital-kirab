---
// Pretty personalized links, e.g. /undangan/andriwijaya → redirects to the
// invitation with the guest's name (and address) prefilled. Unknown/deleted
// slug → plain invitation with no name. Namespacing under /undangan/ keeps guest
// slugs from ever colliding with real top-level routes (/admin, /en, /api, files).
export const prerender = false;

import { getGuestBySlug } from "~/lib/db";

const { slug } = Astro.params;
const guest = slug ? await getGuestBySlug(slug).catch(() => null) : null;

if (!guest) {
  // No such guest (never existed or deleted) → generic invitation, no name.
  return Astro.redirect("/", 302);
}

const name = `${guest.salutation ? guest.salutation + " " : ""}${guest.name}`.trim();
const params = new URLSearchParams({ to: name });
if (guest.address) params.set("alamat", guest.address);
// The redirect drops the slug from the URL; `via` carries it so the landing page
// can attribute the visit/open back to this guest (see CoverGate → /api/track).
if (guest.slug) params.set("via", guest.slug);

return Astro.redirect(`/?${params.toString()}`, 302);
---
