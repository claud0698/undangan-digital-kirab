---
export const prerender = false;

import { getSession } from "~/lib/auth";
import { listGuests, type Guest } from "~/lib/db";
import { CATEGORIES, SALUTATIONS } from "~/lib/categories";

const session = getSession(Astro.cookies);
const guests: Guest[] = session ? await listGuests() : [];
const site = Astro.site?.toString().replace(/\/$/, "") ?? "";
const loginError = Astro.url.searchParams.get("error");

const displayName = (g: Pick<Guest, "salutation" | "name">) =>
  `${g.salutation ? g.salutation + " " : ""}${g.name}`.trim();
const prettyLink = (g: Pick<Guest, "slug">) => (g.slug ? `${site}/${g.slug}` : "");
const fullLink = (g: Pick<Guest, "salutation" | "name" | "address">) => {
  const p = new URLSearchParams({ to: displayName(g) });
  if (g.address) p.set("alamat", g.address);
  return `${site}/?${p.toString()}`;
};
const fmtDate = (iso: string) =>
  new Intl.DateTimeFormat("id-ID", {
    day: "numeric", month: "short", year: "numeric",
    hour: "2-digit", minute: "2-digit", timeZone: "Asia/Jakarta",
  }).format(new Date(iso));
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Admin — Undangan Kirab 2026</title>
    <style>
      :root {
        --bg: #0f0b0b; --panel: #17110f; --line: #2c211c; --line2: #3a2c24;
        --gold: #d8a847; --gold-bright: #f0c869; --text: #efe6d8; --muted: #a99a86;
        --red: #b5321f; --ok: #2f7d4f;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0; background: var(--bg); color: var(--text);
        font: 15px/1.5 -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        -webkit-text-size-adjust: 100%;
      }
      a { color: var(--gold-bright); }
      .wrap { max-width: 1180px; margin: 0 auto; padding: 20px 16px 80px; }
      h1 { font-size: 20px; margin: 0; color: var(--gold-bright); letter-spacing: .02em; }
      .sub { color: var(--muted); font-size: 13px; margin-top: 2px; }
      button, input, select { font: inherit; color: inherit; }
      .btn {
        background: var(--gold); color: #1a1209; border: 0; border-radius: 8px;
        padding: 9px 16px; font-weight: 600; cursor: pointer; white-space: nowrap;
      }
      .btn:hover { background: var(--gold-bright); }
      .btn:disabled { opacity: .5; cursor: default; }
      .btn-ghost { background: transparent; color: var(--muted); border: 1px solid var(--line2); }
      .btn-ghost:hover { color: var(--text); border-color: var(--gold); }
      .btn-sm { padding: 6px 10px; font-size: 13px; border-radius: 6px; }
      .btn-danger { color: #e8a99a; border-color: #4a2a24; }
      .btn-danger:hover { color: #fff; background: var(--red); border-color: var(--red); }
      /* copy buttons: filled gold + dark text so "Salin" is clearly readable */
      .btn[data-copy] { background: var(--gold); color: #1a1209; border: 0; font-weight: 700; }
      .btn[data-copy]:hover { background: var(--gold-bright); color: #1a1209; }

      /* ── login ── */
      .login { max-width: 360px; margin: 12vh auto 0; padding: 28px 24px;
        background: var(--panel); border: 1px solid var(--line); border-radius: 14px; }
      .login h1 { text-align: center; margin-bottom: 4px; }
      .login .sub { text-align: center; margin-bottom: 22px; }
      .field { margin-bottom: 14px; }
      .field label { display: block; font-size: 12px; color: var(--muted); margin-bottom: 6px; text-transform: uppercase; letter-spacing: .08em; }
      .field input {
        width: 100%; padding: 11px 12px; background: #100c0a; border: 1px solid var(--line2);
        border-radius: 8px; outline: none;
      }
      .field input:focus { border-color: var(--gold); }
      .login .btn { width: 100%; padding: 12px; margin-top: 6px; }
      .err { background: #3a1712; border: 1px solid #6e2a1e; color: #f0c0b4;
        padding: 10px 12px; border-radius: 8px; font-size: 13px; margin-bottom: 16px; }

      /* ── dashboard header ── */
      .top { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; margin-bottom: 18px; }
      .toolbar { display: flex; flex-wrap: wrap; gap: 10px; align-items: center; margin-bottom: 16px; }
      .search { flex: 1; min-width: 180px; }
      .search input {
        width: 100%; padding: 10px 12px; background: var(--panel); border: 1px solid var(--line2);
        border-radius: 8px; outline: none;
      }
      .search input:focus { border-color: var(--gold); }
      .sort-select {
        padding: 10px 12px; background: var(--panel); border: 1px solid var(--line2);
        border-radius: 8px; outline: none; cursor: pointer;
      }
      .sort-select:focus { border-color: var(--gold); }
      .count { color: var(--muted); font-size: 13px; }

      .pager { display: flex; align-items: center; justify-content: center; gap: 14px; margin-top: 18px; }
      .pager .page-label { color: var(--muted); font-size: 13px; min-width: 90px; text-align: center; }

      /* ── add form ── */
      .add {
        display: grid;
        grid-template-columns: 140px 1fr 1.3fr 150px 150px auto;
        gap: 10px 12px; background: var(--panel); border: 1px solid var(--line);
        border-radius: 12px; padding: 16px; margin-bottom: 18px; align-items: start;
      }
      .add-field { display: flex; flex-direction: column; gap: 5px; }
      .add input, .add select {
        width: 100%; padding: 10px 11px; background: #100c0a; border: 1px solid var(--line2);
        border-radius: 8px; outline: none; font-size: 16px; /* 16px: readable + avoids iOS focus-zoom */
      }
      .cat-select, .search input, .cell[contenteditable] { font-size: 15px; }
      .add input:focus, .add select:focus { border-color: var(--gold); }
      .add select:invalid { color: var(--muted); }
      .add .hint { font-size: 11px; line-height: 1.35; color: #8a7c6a; }
      .add .btn { align-self: start; margin-top: 1px; }

      /* ── grid (table on desktop) ── */
      .grid { width: 100%; table-layout: fixed; border-collapse: collapse; background: var(--panel);
        border: 1px solid var(--line); border-radius: 12px; overflow: hidden; }
      .grid tbody td { overflow: hidden; text-overflow: ellipsis; }
      .grid tbody td .cell { overflow-wrap: anywhere; }
      .grid thead th {
        text-align: left; font-size: 11px; letter-spacing: .08em; text-transform: uppercase;
        color: var(--muted); padding: 11px 12px; border-bottom: 1px solid var(--line2); font-weight: 600;
      }
      .grid tbody td { padding: 9px 12px; border-bottom: 1px solid var(--line); vertical-align: middle; }
      .grid tbody tr:last-child td { border-bottom: 0; }
      .cell[contenteditable] { outline: none; border-radius: 6px; padding: 4px 6px; min-height: 20px; cursor: text; }
      .cell[contenteditable]:hover { background: #1e1613; }
      .cell[contenteditable]:focus { background: #241a15; box-shadow: inset 0 0 0 1px var(--gold); }
      .cell.slug { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 13px; color: var(--gold-bright); }
      .cat-select {
        background: #100c0a; border: 1px solid var(--line2); border-radius: 7px;
        padding: 6px 8px; outline: none; max-width: 100%;
      }
      .cat-select:focus { border-color: var(--gold); }
      .link-col { display: flex; flex-direction: column; gap: 6px; min-width: 0; }
      .link-row { display: flex; align-items: center; gap: 8px; min-width: 0; }
      .link-row .tag { flex: 0 0 56px; font-size: 10px; text-transform: uppercase; letter-spacing: .05em; color: var(--muted); }
      /* single-line, truncated URL — full URL is available via the Salin button / hover */
      .link-row a { flex: 1; min-width: 0; font-size: 12px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
      .row-actions { display: flex; gap: 6px; justify-content: flex-end; }
      .date-cell { color: var(--muted); font-size: 12.5px; white-space: nowrap; }
      .saving { opacity: .5; }
      .empty-state { text-align: center; color: var(--muted); padding: 40px 12px; }

      .toast { position: fixed; bottom: 20px; left: 50%; transform: translateX(-50%);
        background: var(--ok); color: #fff; padding: 10px 18px; border-radius: 999px; font-size: 14px;
        opacity: 0; pointer-events: none; transition: opacity .2s; z-index: 50; max-width: 90vw; text-align: center; }
      .toast.show { opacity: 1; }
      .toast.err { background: var(--red); }

      /* ── mobile: everything stacks one per line ── */
      @media (max-width: 720px) {
        .add { grid-template-columns: 1fr; }
        .cat-select, .cell[contenteditable], .search input { font-size: 16px; }
        /* toolbar: search full width on its own row; filter + sort share the next row */
        .toolbar { gap: 8px; }
        .toolbar .search { flex: 1 1 100%; min-width: 0; }
        .toolbar .sort-select { flex: 1 1 0; min-width: 0; }
        .toolbar .count { flex: 1 1 100%; }
        .grid, .grid thead, .grid tbody, .grid tr, .grid td { display: block; width: 100%; }
        .grid { border: 0; background: transparent; }
        .grid thead { display: none; }
        .grid tbody tr {
          background: #221611; border: 1px solid #3d2b20; border-left: 3px solid var(--gold);
          border-radius: 12px; margin-bottom: 12px; padding: 6px 4px;
        }
        .grid tbody td { border: 0; padding: 8px 12px; display: flex; gap: 12px; align-items: flex-start; }
        .grid tbody td + td { border-top: 1px solid var(--line); }
        .grid tbody td::before {
          content: attr(data-label); flex: 0 0 90px; color: var(--muted); font-size: 12px;
          text-transform: uppercase; letter-spacing: .05em; padding-top: 6px;
        }
        .cell[contenteditable], .cat-select { flex: 1; }
        /* links: URL on its own full-width line, then [tag ........ Salin] below */
        .link-col { flex: 1; gap: 10px; }
        .link-row { flex-wrap: wrap; gap: 4px 8px; align-items: center; }
        .link-row a { order: 0; flex: 1 1 100%; font-size: 13px; }
        .link-row .tag { order: 1; flex: 0 0 auto; }
        .link-row .btn { order: 2; margin-left: auto; }
        .row-actions { flex: 1; justify-content: flex-start; }
        .date-cell { font-size: 14px; }
      }
    </style>
  </head>
  <body>
    {!session ? (
      <div class="login">
        <h1>Panel Admin</h1>
        <div class="sub">Undangan Kirab Budaya 2026</div>
        {loginError && <div class="err">Username atau password salah.</div>}
        <form method="POST" action="/api/auth/login">
          <div class="field">
            <label for="u">Username</label>
            <input id="u" name="username" autocomplete="username" required autofocus />
          </div>
          <div class="field">
            <label for="p">Password</label>
            <input id="p" name="password" type="password" autocomplete="current-password" required />
          </div>
          <button class="btn" type="submit">Masuk</button>
        </form>
      </div>
    ) : (
      <div class="wrap" data-site={site}>
        <div class="top">
          <div>
            <h1>Manajemen Tamu</h1>
            <div class="sub">Login sebagai <strong>{session.username}</strong></div>
          </div>
          <div style="display:flex; gap:8px;">
            <button class="btn btn-ghost btn-sm" id="csvBtn">Ekspor CSV</button>
            <form method="POST" action="/api/auth/logout" style="margin:0;">
              <button class="btn btn-ghost btn-sm" type="submit">Keluar</button>
            </form>
          </div>
        </div>

        <!-- add guest — all fields required -->
        <form class="add" id="addForm">
          <label class="add-field">
            <input name="salutation" list="salutations" placeholder="Sebutan *" required autocomplete="off" />
            <datalist id="salutations">
              {SALUTATIONS.map((s) => <option value={s} />)}
            </datalist>
            <span class="hint">Panggilan, mis. <em>Bapak</em>, <em>Ibu</em>, <em>Prof.</em> — pilih atau ketik sendiri.</span>
          </label>
          <label class="add-field">
            <input name="name" placeholder="Nama tamu *" required autocomplete="off" />
            <span class="hint">Nama lengkap tamu, mis. <em>Andri Wijaya</em>.</span>
          </label>
          <label class="add-field">
            <input name="address" placeholder="Alamat *" required autocomplete="off" />
            <span class="hint">Alamat / kota, mis. <em>Jl. Melati 12, Tangerang</em>.</span>
          </label>
          <label class="add-field">
            <select name="category" required>
              <option value="" disabled selected>Kategori *</option>
              {CATEGORIES.map((c) => <option value={c}>{c}</option>)}
            </select>
            <span class="hint">Golongan tamu untuk pengelompokan.</span>
          </label>
          <label class="add-field">
            <input name="slug" placeholder="tautan-kustom" autocomplete="off"
              pattern="[a-z0-9-]+" title="huruf kecil, angka, tanda hubung" />
            <span class="hint">Tautan pendek, mis. <em>andriwijaya</em> → <code>{site.replace(/^https?:\/\//, "")}/andriwijaya</code>. Terisi otomatis dari nama.</span>
          </label>
          <button class="btn" type="submit">+ Tambah</button>
        </form>

        <div class="toolbar">
          <div class="search"><input id="search" placeholder="Cari nama / alamat / kategori…" aria-label="Cari" /></div>
          <select id="catFilter" class="sort-select" aria-label="Filter kategori">
            <option value="">Semua Kategori</option>
            {CATEGORIES.map((c) => <option value={c}>{c}</option>)}
          </select>
          <select id="sortBy" class="sort-select" aria-label="Urutkan">
            <option value="terlama" selected>Urut: Terlama</option>
            <option value="terbaru">Urut: Terbaru</option>
            <option value="nama-asc">Urut: Nama A–Z</option>
            <option value="nama-desc">Urut: Nama Z–A</option>
            <option value="kategori">Urut: Kategori</option>
          </select>
          <div class="count"><span id="count">{guests.length}</span> tamu</div>
        </div>

        <table class="grid">
          <thead>
            <tr>
              <th style="width:9%;">Sebutan</th>
              <th style="width:10%;">Nama</th>
              <th style="width:10%;">Alamat</th>
              <th style="width:12%;">Kategori</th>
              <th style="width:9%;">Tautan Kustom</th>
              <th style="width:20%;">Tautan Undangan</th>
              <th style="width:11%;">Ditambah</th>
              <th style="width:8%;">Diaudit oleh</th>
              <th style="width:6%;"></th>
            </tr>
          </thead>
          <tbody id="rows">
            {guests.map((g) => (
              <tr data-id={g.id} data-name={g.name} data-salutation={g.salutation ?? ""}
                  data-address={g.address ?? ""} data-slug={g.slug ?? ""}>
                <td data-label="Sebutan">
                  <div class="cell" contenteditable="plaintext-only" data-field="salutation">{g.salutation ?? ""}</div>
                </td>
                <td data-label="Nama">
                  <div class="cell" contenteditable="plaintext-only" data-field="name">{g.name}</div>
                </td>
                <td data-label="Alamat">
                  <div class="cell" contenteditable="plaintext-only" data-field="address">{g.address ?? ""}</div>
                </td>
                <td data-label="Kategori">
                  <select class="cat-select" data-field="category">
                    {CATEGORIES.map((c) => <option value={c} selected={c === g.category}>{c}</option>)}
                  </select>
                </td>
                <td data-label="Tautan Kustom">
                  <div class="cell slug" contenteditable="plaintext-only" data-field="slug">{g.slug ?? ""}</div>
                </td>
                <td data-label="Tautan">
                  <div class="link-col">
                    <div class="link-row" data-pretty-row style={g.slug ? "" : "display:none"}>
                      <span class="tag">Custom</span>
                      <a href={prettyLink(g)} target="_blank" rel="noopener" data-link-pretty>{prettyLink(g)}</a>
                      <button class="btn btn-ghost btn-sm" data-copy>Salin</button>
                    </div>
                    <div class="link-row">
                      <span class="tag">Lengkap</span>
                      <a href={fullLink(g)} target="_blank" rel="noopener" data-link-full>{fullLink(g)}</a>
                      <button class="btn btn-ghost btn-sm" data-copy>Salin</button>
                    </div>
                  </div>
                </td>
                <td data-label="Ditambah" class="date-cell">{fmtDate(g.created_at)}</td>
                <td data-label="Diaudit oleh" class="date-cell" data-audit>{g.audited_by ?? "—"}</td>
                <td data-label="Aksi">
                  <div class="row-actions">
                    <button class="btn btn-ghost btn-sm btn-danger" data-del>Hapus</button>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
        <div class="empty-state" id="emptyState" style={guests.length ? "display:none" : ""}>
          Belum ada tamu. Tambah tamu pertama di atas.
        </div>
        <div class="pager" id="pager" hidden></div>
      </div>
    )}

    <div class="toast" id="toast"></div>

    {session && (
      <script is:inline define:vars={{ site, CATEGORIES }}>
        const rows = document.getElementById("rows");
        const countEl = document.getElementById("count");
        const emptyState = document.getElementById("emptyState");
        const toastEl = document.getElementById("toast");
        const addForm = document.getElementById("addForm");

        const escapeHtml = (s) =>
          String(s ?? "").replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c]));
        const slugify = (s) =>
          String(s ?? "").toLowerCase().normalize("NFKD").replace(/[^a-z0-9]+/g, "");
        const displayName = (sal, name) => `${sal ? sal + " " : ""}${name}`.trim();
        const fmtDate = (iso) => {
          try {
            return new Intl.DateTimeFormat("id-ID", {
              day: "numeric", month: "short", year: "numeric",
              hour: "2-digit", minute: "2-digit", timeZone: "Asia/Jakarta",
            }).format(new Date(iso));
          } catch { return ""; }
        };
        const prettyLink = (g) => (g.slug ? `${site}/${g.slug}` : "");
        const fullLink = (g) => {
          const p = new URLSearchParams({ to: displayName(g.salutation, g.name) });
          if (g.address) p.set("alamat", g.address);
          return `${site}/?${p.toString()}`;
        };

        let toastTimer;
        const toast = (msg, isErr) => {
          toastEl.textContent = msg;
          toastEl.classList.toggle("err", !!isErr);
          toastEl.classList.add("show");
          clearTimeout(toastTimer);
          toastTimer = setTimeout(() => toastEl.classList.remove("show"), 2000);
        };

        // ── view state: search + sort + pagination ──
        const PAGE_SIZE = 100;
        const pager = document.getElementById("pager");
        let query = "", sortBy = "terlama", catFilter = "", page = 1;

        const byName = (a, b) => (a.dataset.name || "").localeCompare(b.dataset.name || "", "id", { sensitivity: "base" });
        const byId = (a, b) => Number(a.dataset.id) - Number(b.dataset.id);
        const byCat = (a, b) => (a.querySelector(".cat-select")?.value || "").localeCompare(b.querySelector(".cat-select")?.value || "", "id");

        const sortRows = (arr) => {
          if (sortBy === "terbaru") arr.sort((a, b) => byId(b, a));
          else if (sortBy === "terlama") arr.sort(byId);
          else if (sortBy === "nama-asc") arr.sort(byName);
          else if (sortBy === "nama-desc") arr.sort((a, b) => byName(b, a));
          else if (sortBy === "kategori") arr.sort((a, b) => byCat(a, b) || byName(a, b));
          return arr;
        };

        const renderPager = (total, totalPages) => {
          if (total <= PAGE_SIZE) { pager.hidden = true; pager.innerHTML = ""; return; }
          pager.hidden = false;
          pager.innerHTML =
            `<button class="btn btn-ghost btn-sm" data-page="prev"${page <= 1 ? " disabled" : ""}>‹ Sebelumnya</button>` +
            `<span class="page-label">Hal. ${page} / ${totalPages}</span>` +
            `<button class="btn btn-ghost btn-sm" data-page="next"${page >= totalPages ? " disabled" : ""}>Berikutnya ›</button>`;
        };

        const applyView = () => {
          const all = Array.from(rows.children);
          const visible = sortRows(all.filter((tr) =>
            tr.textContent.toLowerCase().includes(query) &&
            (!catFilter || (tr.querySelector(".cat-select")?.value === catFilter))
          ));
          const hidden = all.filter((tr) => !visible.includes(tr));
          visible.forEach((tr) => rows.appendChild(tr));            // reorder to sorted order
          hidden.forEach((tr) => { tr.style.display = "none"; rows.appendChild(tr); });
          const totalPages = Math.max(1, Math.ceil(visible.length / PAGE_SIZE));
          if (page > totalPages) page = totalPages;
          visible.forEach((tr, i) => {
            tr.style.display = Math.floor(i / PAGE_SIZE) + 1 === page ? "" : "none";
          });
          countEl.textContent = visible.length;
          emptyState.style.display = visible.length ? "none" : "";
          renderPager(visible.length, totalPages);
        };
        const updateCount = applyView; // add/delete call this to re-render the view

        const guestOf = (tr) => ({
          salutation: tr.dataset.salutation, name: tr.dataset.name,
          address: tr.dataset.address, slug: tr.dataset.slug,
        });
        const refreshLink = (tr) => {
          const g = guestOf(tr);
          const prettyRow = tr.querySelector("[data-pretty-row]");
          const pretty = tr.querySelector("[data-link-pretty]");
          if (g.slug) {
            const u = prettyLink(g);
            pretty.href = u; pretty.textContent = u;
            prettyRow.style.display = "";
          } else {
            prettyRow.style.display = "none";
          }
          const full = tr.querySelector("[data-link-full]");
          const fu = fullLink(g);
          full.href = fu; full.textContent = fu;
        };

        const catOptions = (selected) =>
          CATEGORIES.map((c) => `<option value="${escapeHtml(c)}"${c === selected ? " selected" : ""}>${escapeHtml(c)}</option>`).join("");

        const buildRow = (g) => {
          const tr = document.createElement("tr");
          tr.dataset.id = g.id;
          tr.dataset.name = g.name;
          tr.dataset.salutation = g.salutation || "";
          tr.dataset.address = g.address || "";
          tr.dataset.slug = g.slug || "";
          const editCell = (field, val, label, cls) =>
            `<td data-label="${label}"><div class="cell ${cls || ""}" contenteditable="plaintext-only" data-field="${field}">${escapeHtml(val)}</div></td>`;
          const pretty = prettyLink(g), full = fullLink(g);
          tr.innerHTML =
            editCell("salutation", g.salutation, "Sebutan") +
            editCell("name", g.name, "Nama") +
            editCell("address", g.address, "Alamat") +
            `<td data-label="Kategori"><select class="cat-select" data-field="category">${catOptions(g.category)}</select></td>` +
            editCell("slug", g.slug, "Tautan Kustom", "slug") +
            `<td data-label="Tautan"><div class="link-col">` +
              `<div class="link-row" data-pretty-row${pretty ? "" : ' style="display:none"'}><span class="tag">Custom</span><a href="${pretty}" target="_blank" rel="noopener" data-link-pretty>${escapeHtml(pretty)}</a><button class="btn btn-ghost btn-sm" data-copy>Salin</button></div>` +
              `<div class="link-row"><span class="tag">Lengkap</span><a href="${escapeHtml(full)}" target="_blank" rel="noopener" data-link-full>${escapeHtml(full)}</a><button class="btn btn-ghost btn-sm" data-copy>Salin</button></div>` +
            `</div></td>` +
            `<td data-label="Ditambah" class="date-cell">${escapeHtml(fmtDate(g.created_at))}</td>` +
            `<td data-label="Diaudit oleh" class="date-cell" data-audit>${escapeHtml(g.audited_by || "—")}</td>` +
            `<td data-label="Aksi"><div class="row-actions"><button class="btn btn-ghost btn-sm btn-danger" data-del>Hapus</button></div></td>`;
          return tr;
        };

        // ── add guest ── auto-fill slug from name unless edited
        const slugInput = addForm.slug, nameInput = addForm.name;
        let slugTouched = false;
        slugInput.addEventListener("input", () => { slugTouched = slugInput.value.trim() !== ""; });
        nameInput.addEventListener("input", () => { if (!slugTouched) slugInput.value = slugify(nameInput.value); });

        addForm.addEventListener("submit", async (e) => {
          e.preventDefault();
          const data = Object.fromEntries(new FormData(addForm));
          if (!data.salutation?.trim() || !data.name?.trim() || !data.address?.trim() || !data.category) {
            return toast("Semua kolom wajib diisi.", true);
          }
          const btn = addForm.querySelector("button");
          btn.disabled = true;
          try {
            const res = await fetch("/api/users", {
              method: "POST", headers: { "content-type": "application/json" }, body: JSON.stringify(data),
            });
            const out = await res.json();
            if (!res.ok) throw new Error(out.error || "gagal");
            rows.prepend(buildRow(out.guest));
            addForm.reset();
            slugTouched = false;
            updateCount();
            toast("Tamu ditambahkan");
          } catch (err) {
            toast("Gagal: " + err.message, true);
          } finally {
            btn.disabled = false;
          }
        });

        // ── inline text edit (delegated): baseline on focus, save on blur if changed
        rows.addEventListener("focusin", (e) => {
          const cell = e.target.closest(".cell[contenteditable]");
          if (cell) cell.dataset.baseline = cell.textContent.trim();
        });
        rows.addEventListener("focusout", async (e) => {
          const cell = e.target.closest(".cell[contenteditable]");
          if (!cell) return;
          const tr = cell.closest("tr");
          const field = cell.dataset.field;
          let value = cell.textContent.trim();
          const baseline = cell.dataset.baseline ?? "";
          if (value === baseline) return;

          if (field === "slug") value = slugify(value.replace(/[^a-z0-9-]/g, ""));
          if ((field === "salutation" || field === "name" || field === "address") && !value) {
            toast(field + " tidak boleh kosong", true);
            cell.textContent = baseline;
            return;
          }
          if (field === "slug" && value) cell.textContent = value; // reflect normalization
          await save(tr, cell, field, value, baseline);
        });

        // ── category select (delegated)
        rows.addEventListener("change", async (e) => {
          const sel = e.target.closest(".cat-select");
          if (!sel) return;
          const tr = sel.closest("tr");
          await save(tr, sel, "category", sel.value, null);
        });

        async function save(tr, el, field, value, baseline) {
          tr.classList.add("saving");
          try {
            const res = await fetch(`/api/users/${tr.dataset.id}`, {
              method: "PATCH", headers: { "content-type": "application/json" }, body: JSON.stringify({ [field]: value }),
            });
            const out = await res.json();
            if (!res.ok) throw new Error(out.error || "gagal");
            const g = out.guest;
            tr.dataset.name = g.name;
            tr.dataset.salutation = g.salutation || "";
            tr.dataset.address = g.address || "";
            tr.dataset.slug = g.slug || "";
            if (el.dataset) el.dataset.baseline = value;
            refreshLink(tr);
            const auditCell = tr.querySelector("[data-audit]");
            if (auditCell && g.audited_by) auditCell.textContent = g.audited_by;
            toast("Tersimpan");
          } catch (err) {
            toast("Gagal: " + err.message, true);
            if (baseline !== null && el.textContent !== undefined) el.textContent = baseline; // revert text cell
          } finally {
            tr.classList.remove("saving");
          }
        }

        // ── copy / delete (delegated)
        rows.addEventListener("click", async (e) => {
          const tr = e.target.closest("tr");
          if (!tr) return;
          if (e.target.closest("[data-copy]")) {
            const url = e.target.closest(".link-row").querySelector("a").href;
            try { await navigator.clipboard.writeText(url); toast("Tautan disalin"); }
            catch { toast("Tidak bisa menyalin", true); }
          }
          if (e.target.closest("[data-del]")) {
            if (!confirm(`Hapus tamu "${tr.dataset.name}"?`)) return;
            tr.classList.add("saving");
            try {
              const res = await fetch(`/api/users/${tr.dataset.id}`, { method: "DELETE" });
              if (!res.ok) throw new Error("gagal");
              tr.remove();
              updateCount();
              toast("Tamu dihapus");
            } catch { tr.classList.remove("saving"); toast("Gagal menghapus", true); }
          }
        });

        // ── search / sort / pager wiring
        document.getElementById("search").addEventListener("input", (e) => {
          query = e.target.value.toLowerCase().trim(); page = 1; applyView();
        });
        document.getElementById("sortBy").addEventListener("change", (e) => {
          sortBy = e.target.value; page = 1; applyView();
        });
        document.getElementById("catFilter").addEventListener("change", (e) => {
          catFilter = e.target.value; page = 1; applyView();
        });
        pager.addEventListener("click", (e) => {
          const btn = e.target.closest("[data-page]");
          if (!btn) return;
          page += btn.dataset.page === "next" ? 1 : -1;
          applyView();
          window.scrollTo({ top: 0, behavior: "smooth" });
        });
        applyView(); // initial sort + paginate

        // ── CSV export
        document.getElementById("csvBtn").addEventListener("click", () => {
          const esc = (v) => `"${String(v || "").replace(/"/g, '""')}"`;
          const lines = [["Sebutan", "Nama", "Alamat", "Kategori", "Tautan Kustom", "Tautan Custom", "Tautan Lengkap"].join(",")];
          rows.querySelectorAll("tr").forEach((tr) => {
            const c = (f) => (tr.querySelector(`[data-field="${f}"]`)?.value ?? tr.querySelector(`[data-field="${f}"]`)?.textContent ?? "").trim();
            const pretty = tr.querySelector("[data-link-pretty]")?.getAttribute("href") || "";
            const full = tr.querySelector("[data-link-full]")?.getAttribute("href") || "";
            lines.push([esc(c("salutation")), esc(c("name")), esc(c("address")), esc(c("category")), esc(c("slug")), esc(pretty), esc(full)].join(","));
          });
          const blob = new Blob(["﻿" + lines.join("\r\n")], { type: "text/csv;charset=utf-8" });
          const a = document.createElement("a");
          a.href = URL.createObjectURL(blob);
          a.download = "tamu-undangan-kirab.csv";
          a.click();
          URL.revokeObjectURL(a.href);
        });
      </script>
    )}
  </body>
</html>
