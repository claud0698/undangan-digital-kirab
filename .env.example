# Auto-scroll drift speed on the cover, in px/second (default 40)
PUBLIC_SCROLL_SPEED=40

# Neon Postgres connection string (guest list). Server-side only — never prefixed PUBLIC_.
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require&channel_binding=require

# HMAC secret for signing admin session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=change-me
